{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                writing_practice_seed_id AS seed_id,\n                seq,\n                prompt,\n                answer,\n                hint\n            FROM writing_practice_seed\n            WHERE writing_level = $1\n              AND writing_practice_type = $2\n            ORDER BY seq ASC\n            LIMIT $3\n            ",
