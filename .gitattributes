# N-22: 줄바꿈 정책 LF 통일 (Windows ↔ Unix 일관성, diff 노이즈 차단)

# 모든 텍스트 파일 자동 감지 + LF 강제
* text=auto eol=lf

# 명시 텍스트 (혼란 방지)
*.rs       text eol=lf
*.toml     text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.sql      text eol=lf
*.json     text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.css      text eol=lf
*.html     text eol=lf
*.sh       text eol=lf
.env*      text eol=lf
Dockerfile text eol=lf

# 바이너리 (diff 비활성)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.pdf   binary

# SVG = 텍스트로 처리 (수정 가능)
*.svg   text eol=lf
