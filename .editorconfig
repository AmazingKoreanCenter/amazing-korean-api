# N-22: 편집기 일관성 (https://editorconfig.org/)
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Rust = rustfmt 기본 4 스페이스
[*.rs]
indent_size = 4
max_line_length = 100

# TOML / YAML = 2 스페이스
[*.{toml,yml,yaml}]
indent_size = 2

# Markdown = trailing whitespace 의도된 line break (보존)
[*.md]
trim_trailing_whitespace = false

# Shell = 2 스페이스
[*.{sh,bash}]
indent_size = 2

# SQL = 2 스페이스
[*.sql]
indent_size = 2

# Makefile = 탭 강제
[Makefile]
indent_style = tab
