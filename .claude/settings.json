{
  "permissions": {
    "allow": [
      "Bash(cargo build:*)",
      "Read(/tmp/amk-translate/**)",
      "Write(/tmp/amk-translate/**)",
      "Edit(/tmp/amk-translate/**)",
      "Bash(awk '{print $5, $9}')",
      "Bash(awk '{print $2}')",
      "Bash(awk -F'-' '{print \"3rd group [\"$3\"]  →  version nibble=\"substr\\($3,1,1\\)\"  →  variant nibble=\"substr\\($4,1,1\\)}')",
      "Bash(set -e)",
      "Bash(awk 'BEGIN{b=0} /^$/{b=1;next} !b{print} b{print \"BODY:\",$0}')",
      "Bash(awk '{print $3}')",
      "Bash(DATABASE_URL='postgres://postgres:postgres@127.0.0.1:5432/amazing_korean_db' cargo sqlx prepare --workspace -- --all-targets)"
    ]
  }
}
